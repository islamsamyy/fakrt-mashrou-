    "api_routes": [
      {
        "path": "/api/invest",
        "method": "POST",
        "auth_required": true,
        "rate_limit": "Standard",
        "description": "Create new investment record",
        "validation": [
          "projectId (required, string)",
          "amount (required, number, 1000-10000000 SAR)",
          "notes (optional, string)"
        ],
        "response_format": {
          "success": "boolean",
          "data": {
            "investmentId": "string",
            "projectId": "string",
            "amount": "number",
            "status": "string (pending)"
          },
          "error": "string",
          "statusCode": "number"
        },
        "error_cases": [
          {
            "400": "Invalid project ID, amount not a number, amount too low/high"
          },
          {
            "401": "User not authenticated"
          },
          {
            "403": "Investor trying to invest in own project"
          },
          {
            "404": "Project not found"
          },
          {
            "409": "Project not accepting investments, duplicate investment attempt"
          }
        ]
      },
      {
        "path": "/api/webhooks/stripe",
        "method": "POST",
        "auth_required": false,
        "description": "Stripe webhook for payment confirmation",
        "events_handled": [
          "checkout.session.completed"
        ],
        "actions": [
          "Update investment status to 'paid'",
          "Send investment confirmation notification"
        ],
        "security": [
          "Signature verification required",
          "Metadata validation"
        ]
      },
      {
        "path": "/auth/callback",
        "method": "GET",
        "auth_required": false,
        "description": "OAuth callback handler for Supabase Auth"
      }
