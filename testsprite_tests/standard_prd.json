    "database_schema": {
      "tables": [
        {
          "name": "profiles",
          "purpose": "User account information",
          "columns": [
            "id (UUID, PK, FK auth.users)",
            "email (string)",
            "full_name (string)",
            "avatar_url (string)",
            {
              "role (enum": "founder, investor, admin)"
            },
            {
              "kyc_status (enum": "pending, approved, rejected)"
            },
            "kyc_data (jsonb)",
            "created_at (timestamp)",
            "updated_at (timestamp)"
          ]
        },
        {
          "name": "projects",
          "purpose": "Investment opportunities/ideas",
          "columns": [
            "id (UUID, PK)",
            "founder_id (UUID, FK profiles)",
            "title (string)",
            "description (text)",
            "category (string)",
            "funding_goal (number)",
            "amount_raised (number)",
            {
              "status (enum": "draft, active, inactive, completed, cancelled)"
            },
            "verified (boolean)",
            "ai_score (number)",
            "img (string)",
            "min_invest (number)",
            "created_at (timestamp)",
            "updated_at (timestamp)"
          ]
        },
        {
          "name": "investments",
          "purpose": "Investment transactions",
          "columns": [
            "id (UUID, PK)",
            "investor_id (UUID, FK profiles)",
            "project_id (UUID, FK projects)",
            "amount (number)",
            {
              "status (enum": "pending, committed, paid, cancelled)"
            },
            "notes (text)",
            "created_at (timestamp)",
            "updated_at (timestamp)"
          ]
        },
        {
          "name": "messages",
          "purpose": "User-to-user communication",
          "columns": [
            "id (UUID, PK)",
            "sender_id (UUID, FK profiles)",
            "receiver_id (UUID, FK profiles)",
            "content (text)",
            "read (boolean)",
            "created_at (timestamp)"
          ]
        },
        {
          "name": "saved_opportunities",
          "purpose": "Bookmarked projects",
          "columns": [
            "id (UUID, PK)",
            "user_id (UUID, FK profiles)",
            "project_id (UUID, FK projects)",
            "created_at (timestamp)"
          ]
        },
        {
          "name": "notifications",
          "purpose": "User notifications",
          "columns": [
            "id (UUID, PK)",
            "user_id (UUID, FK profiles)",
            {
              "type (enum": "investment, message, status, kyc)"
            },
            "title (string)",
            "message (text)",
            "link (string)",
            "read (boolean)",
            "created_at (timestamp)"
          ]
        }
      ]
    },
